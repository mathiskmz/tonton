<div class="container text-center">
        <%= link_to "← Mes chats", chats_path %>

    <h1 id="chat_title"><%= @chat.title %></h1>

    <div id="messages">
    <% @chat.messages.each do |message| %>
        <% if message.role == "user" %>
        <div class="d-flex justify-content-end mb-2">
            <div class="bg-white text-dark px-3 py-2 rounded-4 d-inline-block text-start" style="max-width: 75%;">
                <%= message.content %>
            </div>
        </div>
        <% elsif message.role == "assistant" %>
        <div class="d-flex justify-content-start mb-2">
            <div class="bg-primary text-white px-3 py-2 rounded-4 d-inline-block text-start" style="max-width: 75%;">
                <%= simple_format(message.content) %>
            </div>
        </div>
        <% end %>
    <% end %>
    </div>

<div id="new_message_container">
    <%= simple_form_for [@chat, @message] do |f| %>
        <%= f.input :content, label: "Ask a question", required: true, placeholder: "How should I get started with the challenge?" %>
        <%= f.button :submit, 'Ask Tonton', class: 'btn btn-primary' %>
    <% end %>
    </div>

</div>
