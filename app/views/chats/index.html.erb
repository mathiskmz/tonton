.<div class="container">
    <div class="">
        <h1>Mes conversations</h1>
        <%= link_to "Nouveau chat", new_chat_path, class:"btn btn-warning align-self-center rounded-pill" %>
        <%= link_to "C'est quoi l'actu ?", create_from_news_checkup_chats_path, method: :post, class:"btn btn-success text-white align-self-center rounded-pill shadow-sm" %>
    </div>

    <div class="row">
        <% @chats.each do |chat| %>
            <div class="card col-4 shadow p-3 m-1 rounded-5 border border-0" style="width: 18rem;">
            <%= image_tag "glasses.png" %> <%# herb:disable html-img-require-alt %>
            <div class="card-body">
                <h5 class="card-title"> <%= chat.title %></h5>
                <%# <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card’s content.</p> %>
                <%= link_to "Ouvrir", chat_path(chat), class:"btn btn-primary rounded-pill" %>
            </div>
            </div>
        <% end %>
    </div>
</div>
