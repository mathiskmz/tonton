<h1>Modifier la conversation</h1>
<p>Titre: <%= @chat.title %> | Créé le : <%= @chat.created_at %> | Mis à jour le : <%= @chat.updated_at %></p>
<%= simple_form_for @chat do |f| %>
  <%= f.input :title, placeholder: @chat.title, label: "Nouveau titre :" %>
  <%= f.button :submit, class:"btn btn-info" %>
<% end %>
